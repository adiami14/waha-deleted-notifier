# WAHA connectivity
WAHA_BASE_URL=http://localhost:3000
WAHA_API_KEY=your_api_key_here

# Sessions
WAHA_LISTEN_SESSION=listener
WAHA_NOTIFY_SESSION=default

# WhatsApp group that receives deletion notifications (must be a group JID)
# Find the group JID via WAHA API: GET /api/{session}/groups
NOTIFY_GROUP_ID=YOUR_GROUP_JID@g.us

# How many days to keep downloaded media files
DAYS_TO_SAVE_FILES=7

# Local paths (used inside Docker via volume)
MEDIA_DIR=/data/media
DB_PATH=/data/bot.db

# Deduplication (recommended: true)
WEBHOOK_DEDUP_ENABLED=true

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Wet-test variables (only needed when running wet_tests/) ──────────────────
# WET_TEST_SENDER_SESSION=sender
# WET_TEST_LISTENER_JID=972501234567@c.us
